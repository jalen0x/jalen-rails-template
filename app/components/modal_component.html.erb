<div class="fixed inset-0 z-50 flex items-center justify-center overflow-y-auto bg-black/50" data-controller="modal">
  <div class="relative w-full <%= size_class %> mx-auto my-6">
    <div class="bg-neutral-primary-soft border border-default rounded-base shadow-xs">
      <% if header? || title.present? %>
        <div class="flex items-start justify-between px-6 py-4 border-b border-default">
          <h3 class="text-lg font-semibold text-heading">
            <%= header? ? header : title %>
          </h3>
          <button type="button" class="text-body hover:text-heading" data-action="modal#close" aria-label="Close">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
      <% end %>

      <div class="px-6 py-4 text-body">
        <%= content %>
      </div>

      <% if footer? %>
        <div class="flex items-center justify-end gap-2 px-6 py-4 border-t border-default">
          <%= footer %>
        </div>
      <% end %>
    </div>
  </div>
</div>
