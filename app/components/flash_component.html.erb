<% if banner_messages.any? %>
  <div id="flash" class="mx-auto flex w-full max-w-7xl flex-col gap-3 px-6 pt-4 sm:px-8" data-turbo-temporary>
    <% banner_messages.each do |banner| %>
      <div class="flex items-start gap-3 rounded-base border p-4 shadow-xs <%= banner_classes(banner[:kind]) %>" role="alert">
        <div class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full <%= banner_badge_classes(banner[:kind]) %>">
          <% if banner[:kind] == :alert %>
            <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none">
              <path d="M12 8v5m0 3h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
            </svg>
          <% else %>
            <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none">
              <path d="M12 8h.01M11 12h1v4h1m8-4a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
            </svg>
          <% end %>
          <span class="sr-only"><%= banner_label(banner[:kind]) %></span>
        </div>

        <div class="min-w-0 flex-1 text-sm leading-6">
          <%= sanitize(banner[:message]) %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<% toast_positions.each do |position| %>
  <div
    id="<%= toast_container_id(position) %>"
    class="<%= toast_container_classes(position) %>"
    data-controller="toast-list"
    data-toast-list-position-value="<%= position %>"
    data-turbo-temporary>
    <% toasts_for(position).each do |toast| %>
      <%= render(ToastComponent.new(**toast)) %>
    <% end %>
  </div>
<% end %>
