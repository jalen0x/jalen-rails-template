# Only RAILS_MASTER_KEY lives in 1Password — it's what unlocks everything else.
# Replace vault-uuid/item-uuid with the actual 1Password vault + item ids
# holding your RAILS_MASTER_KEY field.
SECRETS=$(kamal secrets fetch --adapter 1password --account my --from vault-uuid/item-uuid RAILS_MASTER_KEY)
RAILS_MASTER_KEY=$(kamal secrets extract RAILS_MASTER_KEY ${SECRETS})

# Everything else is decrypted locally at deploy time from Rails production
# credentials. Create them with:
#   bin/rails credentials:edit -e production
# and populate kamal.registry_password, database.password, ssl.certificate,
# ssl.private_key (plus any app-level keys Rails needs). production.yml.enc
# must be decryptable with RAILS_MASTER_KEY — align config/credentials/production.key
# with config/master.key (or just delete production.key after the first edit
# and the env var will be used).
KAMAL_REGISTRY_PASSWORD=$(bin/rails credentials:show -e production | ruby -ryaml -e 'puts YAML.safe_load(STDIN.read).dig("kamal", "registry_password")')
POSTGRES_PASSWORD=$(bin/rails credentials:show -e production | ruby -ryaml -e 'puts YAML.safe_load(STDIN.read).dig("database", "password")')
SSL_CERTIFICATE=$(bin/rails credentials:show -e production | ruby -ryaml -e 'print YAML.safe_load(STDIN.read).dig("ssl", "certificate")')
SSL_PRIVATE_KEY=$(bin/rails credentials:show -e production | ruby -ryaml -e 'print YAML.safe_load(STDIN.read).dig("ssl", "private_key")')
