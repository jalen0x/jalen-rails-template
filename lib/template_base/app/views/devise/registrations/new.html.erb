<% content_for(:title) { t(".title") } %>
<% @hide_flash_alert = true %>

<% content_for :form_block do %>
  <div class="mb-6 text-center">
    <h2 class="mb-1 text-2xl font-bold leading-tight text-heading"><%= t(".sign_up") %></h2>
    <p class="text-sm text-body-subtle">
      <%= t(".login_html", link: link_to(t(".login_link"), new_session_path(resource_name), data: modal_turbo_frame_data, class: "font-medium text-fg-brand hover:underline")) %>
    </p>
  </div>

  <%= render "devise/shared/oauth_buttons" %>

  <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), data: modal_turbo_frame_data) do |f| %>
    <% if resource.errors.any? %>
      <div class="mb-6 rounded-base border border-danger-subtle bg-danger-soft px-4 py-3 text-sm text-fg-danger-strong">
        <p class="font-medium"><%= t("errors.messages.not_saved", count: resource.errors.count, resource: resource.class.model_name.human.downcase) %></p>
        <ul class="mt-2 list-disc space-y-1 ps-5">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-6">
      <%= f.label :email, class: "block mb-2 text-sm font-medium text-heading" %>
      <%= f.email_field :email, autocomplete: "email", placeholder: true, required: true, class: "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>
    </div>

    <div class="mb-6">
      <%= f.label :password, class: "block mb-2 text-sm font-medium text-heading" %>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: true, required: true, class: "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>
      <% if @minimum_password_length %>
        <p class="mt-2 text-sm text-body-subtle"><%= t("devise.shared.minimum_password_length", count: @minimum_password_length) %></p>
      <% end %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, class: "block mb-2 text-sm font-medium text-heading" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: true, required: true, class: "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>
    </div>

    <%= f.button button_text(t(".sign_up"), disable_with: t(".submitting")), class: "w-full text-white bg-brand box-border border border-transparent hover:bg-brand-strong focus:ring-4 focus:outline-none focus:ring-brand-medium shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 text-center" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>

<%= render "devise/shared/form_block" %>
