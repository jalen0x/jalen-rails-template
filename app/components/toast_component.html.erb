<div
  class="w-full transform-gpu transition-transform duration-300 ease-out"
  data-controller="toast"
  data-toast-dismiss-after-value="<%= dismiss_after %>"
  data-toast-list-target="toast">
  <div
    class="pointer-events-auto flex w-full items-start gap-3 rounded-base border border-default bg-neutral-primary-soft p-4 shadow-xs transition-all duration-200 ease-out"
    role="alert"
    aria-live="<%= aria_live %>"
    data-toast-target="content">
    <div class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full <%= badge_classes %>">
      <% case variant %>
      <% when :success %>
        <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none">
          <path d="M5 11.917 9.724 16.5 19 7.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
        </svg>
        <span class="sr-only">Success</span>
      <% when :danger %>
        <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none">
          <path d="M6 18 18 6M18 18 6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
        </svg>
        <span class="sr-only">Error</span>
      <% when :warning %>
        <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none">
          <path d="M12 8v5m0 3h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
        </svg>
        <span class="sr-only">Warning</span>
      <% else %>
        <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none">
          <path d="M12 8h.01M11 12h1v4h1m8-4a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
        </svg>
        <span class="sr-only">Info</span>
      <% end %>
    </div>

    <div class="min-w-0 flex-1 text-sm leading-6 text-body">
      <div><%= sanitize(message) %></div>

      <% if link.present? %>
        <div class="mt-1.5">
          <%= link_to link[:text], link[:url], class: link_classes %>
        </div>
      <% end %>
    </div>

    <% if dismissable %>
      <button
        type="button"
        class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-base border border-transparent bg-transparent text-body hover:bg-neutral-secondary-medium hover:text-heading focus:outline-none focus:ring-4 focus:ring-neutral-tertiary"
        data-action="toast#close"
        aria-label="Close">
        <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none">
          <path d="M6 18 18 6M18 18 6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
        </svg>
      </button>
    <% end %>
  </div>
</div>
