<%- if devise_mapping.omniauthable? && %w[registrations sessions].include?(controller_name) %>
  <%- providers = resource_class.omniauth_providers %>

  <%- if providers.any? %>
    <div class="space-y-3">
      <%- providers.each do |provider| %>
        <%= button_to public_send("#{resource_name}_#{provider}_omniauth_authorize_path"),
            method: :post,
            form: { class: "w-full" },
            class: social_button_class,
            data: { turbo: false, disable_with: t("devise.shared.links.redirecting") } do %>
          <%= oauth_provider_icon_svg(provider) %>
          <%= t("oauth.sign_in_with", provider: t("oauth.#{provider}")) %>
        <% end %>
      <% end -%>
    </div>

    <div class="flex items-center">
      <div class="h-0.5 w-full bg-neutral-quaternary"></div>
      <div class="px-5 text-center text-body-subtle"><%= t("devise.shared.or") %></div>
      <div class="h-0.5 w-full bg-neutral-quaternary"></div>
    </div>
  <% end %>
<% end -%>
