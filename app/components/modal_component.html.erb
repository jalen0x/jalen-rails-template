<div class="fixed inset-0 z-50 flex items-center justify-center overflow-y-auto bg-black/50" data-controller="modal" data-action="click->modal#backdropClose turbo:submit-end->modal#submitEnd">
  <div class="relative w-full <%= size_class %> mx-auto my-6">
    <div class="relative bg-neutral-primary-soft border border-default rounded-base shadow-xs">
      <% if header? || title.present? %>
        <div class="flex items-start justify-between px-6 py-4 border-b border-default">
          <h3 class="text-lg font-semibold text-heading">
            <%= header? ? header : title %>
          </h3>
          <button type="button" class="text-body hover:text-heading" data-action="modal#close" aria-label="<%= t("components.modal.close") %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
      <% elsif close_button? %>
        <button type="button" class="absolute top-4 right-4 z-10 inline-flex h-9 w-9 items-center justify-center rounded-base bg-transparent text-sm text-body hover:bg-neutral-tertiary hover:text-heading" data-action="modal#close" aria-label="<%= t("components.modal.close") %>">
          <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6" /></svg>
        </button>
      <% end %>

      <div class="<%= body_class %>">
        <%= content %>
      </div>

      <% if footer? %>
        <div class="flex items-center justify-end gap-2 px-6 py-4 border-t border-default">
          <%= footer %>
        </div>
      <% end %>
    </div>
  </div>
</div>
