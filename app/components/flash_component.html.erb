<div class="fixed top-5 right-5 z-50 space-y-2" data-controller="flash">
  <% flash.each do |kind, message| %>
    <div class="flex items-center w-full max-w-xs p-4 rounded-base shadow-xs <%= classes_for(kind) %>" role="alert">
      <div class="text-sm font-medium"><%= message %></div>
    </div>
  <% end %>
</div>
